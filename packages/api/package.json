{
  "name": "@kando/api",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    }
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache dist node_modules",
    "dev": "tsc",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@kando/auth": "workspace:*",
    "@kando/db": "workspace:*",
    "@trpc/server": "^11.18.0",
    "superjson": "2.2.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@kando/eslint-config": "workspace:*",
    "@kando/prettier-config": "workspace:*",
    "@kando/tsconfig": "workspace:*",
    "eslint": "^9.39.5",
    "prettier": "^3.9.5",
    "typescript": "^5.9.3"
  },
  "prettier": "@kando/prettier-config"
}
