{
  "name": "kando-monorepo",
  "private": true,
  "engines": {
    "node": "^24.12.0",
    "pnpm": "^10.19.0"
  },
  "packageManager": "pnpm@10.19.0",
  "scripts": {
    "build": "pnpm -r build",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "pnpm -r clean",
    "auth:generate": "pnpm -F @kando/auth generate",
    "db:push": "pnpm -F @kando/db push",
    "db:studio": "pnpm -F @kando/db studio",
    "dev": "pnpm -r run dev",
    "dev:next": "pnpm -F @kando/nextjs dev",
    "format": "pnpm -r format --continue -- --cache --cache-location .cache/.prettiercache",
    "format:fix": "pnpm -r format --continue -- --write --cache --cache-location .cache/.prettiercache",
    "lint": "pnpm -r lint --continue -- --cache --cache-location .cache/.eslintcache",
    "lint:fix": "pnpm -r lint --continue -- --fix --cache --cache-location .cache/.eslintcache",
    "lint:ws": "pnpm dlx sherif@latest",
    "typecheck": "pnpm -r typecheck",
    "ui-add": "pnpm -r ui-add",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "devDependencies": {
    "@kando/prettier-config": "workspace:*",
    "dotenv-cli": "^11.0.0",
    "prettier": "^3.9.5",
    "typescript": "^5.9.3"
  },
  "prettier": "@kando/prettier-config"
}
