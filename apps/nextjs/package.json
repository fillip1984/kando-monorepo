{
  "name": "@kando/nextjs",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm with-env next build",
    "clean": "git clean -xdf .cache .next .turbo node_modules",
    "dev": "pnpm with-env next dev",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "start": "pnpm with-env next start",
    "typecheck": "tsc --noEmit",
    "with-env": "dotenv -e ../../.env --"
  },
  "dependencies": {
    "@kando/api": "workspace:*",
    "@kando/auth": "workspace:*",
    "@kando/db": "workspace:*",
    "@t3-oss/env-nextjs": "^0.13.8",
    "@tanstack/react-form": "^1.33.0",
    "@tanstack/react-query": "^5.101.2",
    "@trpc/client": "^11.18.0",
    "@trpc/server": "^11.18.0",
    "@trpc/tanstack-react-query": "^11.18.0",
    "better-auth": "1.6.23",
    "next": "^16.0.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "superjson": "2.2.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@kando/eslint-config": "workspace:*",
    "@kando/prettier-config": "workspace:*",
    "@kando/tailwind-config": "workspace:*",
    "@kando/tsconfig": "workspace:*",
    "@types/node": "26.1.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "^9.39.4",
    "jiti": "^2.5.1",
    "prettier": "^3.9.5",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3"
  },
  "prettier": "@kando/prettier-config"
}
